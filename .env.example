# ======================
# CareVoice AI Hospital Platform
# Environment Configuration
# ======================
# Copy this file to .env and fill in your values.
# DATABASE_URL and REDIS_URL are overridden by docker-compose.yml
# for Docker deployments — you only need them for local bare-metal runs.

# --- Application ---
APP_NAME=CareVoice AI Hospital
DEBUG=false
BASE_URL=http://localhost:8000

# --- Database ---
# For Docker: overridden automatically by docker-compose.yml
# For local dev: set to your local Postgres instance
DATABASE_URL=postgresql+asyncpg://postgres:your_db_password@localhost:5432/postgres

# --- Redis ---
# For Docker: overridden automatically by docker-compose.yml
# For local dev: set to your local Redis instance
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=change-this-to-a-random-secret-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Email / SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@carevoice.ai

# --- Business Config ---
GST_RATE=18.0
SLOT_LOCK_TTL_SECONDS=300

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]