# =============================================================================
# CareVoice AI Hospital Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://carevoice:carevoice_secret_2026@localhost:5432/carevoice_db
DATABASE_SYNC_URL=postgresql://carevoice:carevoice_secret_2026@localhost:5432/carevoice_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT ---
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBHOOK_URL=https://your-domain.com/api/v1/voice/incoming

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hospital@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@carevoice.ai
SMTP_FROM_NAME=CareVoice AI Hospital

# --- WhatsApp (Twilio) ---
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- AWS S3 (Optional) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=carevoice-documents
AWS_REGION=ap-south-1

# --- Sentry ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# --- App ---
APP_NAME=CareVoice AI
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Hospital Config ---
HOSPITAL_NAME=CareVoice Medical Center
HOSPITAL_PHONE=+91-1234567890
HOSPITAL_EMAIL=info@carevoice.ai
GST_PERCENTAGE=18.0
DEFAULT_SLOT_DURATION_MINUTES=20
SLOT_LOCK_TIMEOUT_SECONDS=300
