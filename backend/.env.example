# ======================
# CareVoice AI Hospital Platform
# Environment Configuration
# ======================

# --- Application ---
APP_NAME=CareVoice AI Hospital
DEBUG=false
BASE_URL=http://localhost:8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://carevoice_user:your_password@localhost:5432/carevoice_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Gemini ---
GEMINI_API_KEY=your-gemini-api-key



# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Email / SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-smtp-app-password
FROM_EMAIL=noreply@carevoice.ai

# --- Business Config ---
GST_RATE=18.0
SLOT_LOCK_TTL_SECONDS=300

# --- Admin Seeding ---
# Credentials used when the seed script creates the default admin user
ADMIN_EMAIL=admin@carevoice.ai
ADMIN_PASSWORD=changeme_in_production
ADMIN_FULL_NAME=System Administrator

# --- Testing / Demo ---
# Set TEST_FEE_DISCOUNT_PERCENT to e.g. 99 during development so Razorpay only
# charges ~1% of the invoice total (e.g. ₹1500 appointment → ₹15 actual charge).
# The DB invoice and charts always store the full realistic amount.
# Set to 0 in production.
TEST_FEE_DISCOUNT_PERCENT=0

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
